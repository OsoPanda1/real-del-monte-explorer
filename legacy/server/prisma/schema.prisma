generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS & AUTHENTICATION ====================

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          Role     @default(tourist)
  avatarUrl     String?  @map("avatar_url")
  isActive      Boolean  @default(true) @map("is_active")
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  touristProfile   TouristProfile?
  business        Business?
  posts            Post[]
  postLikes       PostLike[]
  postComments     PostComment[]
  aiSessions       AiSession[]
  tipsSent         Tip[]       @relation("TipsSent")
  analytics        AnalyticsEvent[]
  passwordResets   PasswordReset[]
  emailVerifications EmailVerification[]
  donations        Donation[]

  @@map("users")
}

enum Role {
  tourist
  business_owner
  admin
}

model TouristProfile {
  id                    String       @id @default(uuid())
  userId                String       @unique @map("user_id")
  homeCity              String?      @map("home_city")
  travelStyle           TravelStyle? @map("travel_style")
  preferredDuration     Int?         @map("preferred_duration_hours")
  hasKids               Boolean?     @default(false) @map("has_kids")
  notes                 String?
  language              String       @default("es")
  notificationsEnabled  Boolean      @default(true) @map("notifications_enabled")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tourist_profiles")
}

enum TravelStyle {
  relax
  adventure
  family
  culture
  foodie
}

// ==================== BUSINESSES ====================

model Business {
  id                   String   @id @default(uuid())
  ownerId              String?  @unique @map("owner_id")
  name                 String
  category             BusinessCategory @map("business_category")
  subcategory          String?  @map("subcategory")
  description          String   @db.Text
  shortDescription     String?  @map("short_description") // Max 500 chars for display
  
  // Contact info
  phone                String?
  whatsapp             String?
  email                String?
  website              String?
  
  // Address
  address              String?
  addressReference     String?  @map("address_reference") // For directions
  latitude             Float?
  longitude            Float?
  
  // Media - Up to 3 images, 1 video
  imageUrl             String?  @map("image_url")
  imageUrl2            String?  @map("image_url_2")
  imageUrl3            String?  @map("image_url_3")
  videoUrl             String?  @map("video_url")
  videoDuration        Int?     @map("video_duration_seconds") // Max 60 seconds
  
  // Schedule
  schedule             Json?    // { monday: {open: "09:00", close: "18:00", closed: false}, ... }
  scheduleDisplay      String?  @map("schedule_display") // Human readable
  
  // Social media
  facebook             String?
  instagram            String?
  tiktok               String?
  twitter              String?
  youtube              String?
  
  // Business details
  priceRange          PriceRange? @map("price_range")
  acceptsReservations  Boolean  @default(false) @map("accepts_reservations")
  hasParking          Boolean  @default(false) @map("has_parking")
  isAccessible        Boolean  @default(false) @map("is_accessible")
  paymentMethods       String[] @default([]) @map("payment_methods")
  languages           String[] @default(["es"]) @map("languages")
  
  // Status
  isPremium            Boolean  @default(false) @map("is_premium")
  premiumUntil         DateTime? @map("premium_until")
  subscriptionStatus   SubscriptionStatus @default(NONE) @map("subscription_status")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  isFeatured          Boolean  @default(false) @map("is_featured")
  isActive             Boolean  @default(true) @map("is_active")
  isVerified           Boolean  @default(false) @map("is_verified")
  
  // Admin fields
  approvedAt          DateTime? @map("approved_at")
  approvedBy          String?   @map("approved_by")
  rejectionReason      String?  @map("rejection_reason")
  
  // Stats
  viewsCount          Int      @default(0) @map("views_count")
  rating              Float?   @default(0)
  reviewsCount        Int      @default(0) @map("reviews_count")
  
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tipsReceived Tip[] @relation("TipsToBusiness")
  liveEvents   LiveEvent[]
  contentRecommendations ContentRecommendation[]
  routeStops   RouteStopBusiness[]
  owner           User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  tipsReceived   Tip[]         @relation("TipsToBusiness")
  donations      Donation[]

  @@map("businesses")
}

enum BusinessCategory {
  GASTRONOMIA  // Restaurants, cafes, bars
  HOSPEDAJE    // Hotels, hostels, cabañas
  ARTESANIA    // Crafts, jewelry
  PLATERIA     // Silver work
  BAR          // Bars, cantinas
  COMERCIO     // Shops, stores
  SERVICIOS    // Services (guides, rentals, etc.)
  TURISMO      // Tour operators
  OTROS        // Other categories
}

enum PriceRange {
  ECONOMICO
  MODERADO
  CARO
  LUJO
}

enum SubscriptionStatus {
  NONE
  PENDING
  ACTIVE
  EXPIRED
}

// ==================== DICHOS MINEROS ====================

model DichosMiner {
  id          String   @id @default(uuid())
  texto       String
  significado String?  @map("significado")
  categoria   DichosCategoria @default(GENERAL) @map("categoria")
  fuente      String?
  tags        String[] @default([])
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("dichos_mineros")
}

enum DichosCategoria {
  GENERAL
  BRINDIS
  HUMOR
  FAMILIA
  COMIDA_BEBIDA
  TRABAJO
  VIDA_COTIDIANA
  MINERIA
}

// ==================== NEWSLETTER ====================

model NewsletterSubscriber {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String?
  isVerified      Boolean  @default(false) @map("is_verified")
  verificationToken String? @map("verification_token")
  subscribedAt    DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")
  source          String   @default("website")
  providerId      String?  @map("provider_id") // Mailchimp/Brevo ID
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("newsletter_subscribers")
}

// ==================== DONATIONS ====================

model Donation {
  id                String        @id @default(uuid())
  userId            String?       @map("user_id")
  businessId        String?       @map("business_id")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("MXN")
  type              DonationType  @map("donation_type")
  status            DonationStatus @default(pending)
  stripeSessionId   String?       @unique @map("stripe_session_id")
  stripePaymentId   String?       @map("stripe_payment_id")
  stripeCustomerId String?       @map("stripe_customer_id")
  message           String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  business  Business?  @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@map("donations")
}

enum DonationType {
  donation   // General donation to support the platform
  premium    // Payment to upgrade business to premium
}

enum DonationStatus {
  pending
  completed
  failed
  refunded
}

// ==================== PASSWORD RESET ====================

model PasswordReset {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  token         String   @unique
  expiresAt     DateTime @map("expires_at")
  usedAt        DateTime? @map("used_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ==================== EMAIL VERIFICATION ====================

model EmailVerification {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  token         String   @unique
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ==================== POST MODERATION ====================

model Post {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  placeName     String   @map("place_name")
  content       String
  imageUrl      String?  @map("image_url")
  likesCount    Int      @default(0) @map("likes_count")
  commentsCount Int      @default(0) @map("comments_count")
  isModerated   Boolean  @default(false) @map("is_moderated")
  isHidden      Boolean  @default(false) @map("is_hidden")
  isFeatured    Boolean  @default(false) @map("is_featured")
  moderatedAt   DateTime? @map("moderated_at")
  moderatedBy   String?  @map("moderated_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    PostLike[]
  comments PostComment[]

  @@map("posts")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_comments")
}

// ==================== EVENTS & ROUTES ====================

model Event {
  id          String    @id @default(uuid())
  title       String
  description String
  location    String
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  imageUrl    String?   @map("image_url")
  isFeatured  Boolean   @default(false) @map("is_featured")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("events")
}

model Route {
  id                 String        @id @default(uuid())
  name               String
  description        String
  difficulty         Difficulty
  durationMinutes    Int           @map("duration_minutes")
  distanceKm         Float?        @map("distance_km")
  imageUrl           String?       @map("image_url")
  isNightRoute       Boolean       @default(false) @map("is_night_route")
  isFamilyFriendly   Boolean       @default(true) @map("is_family_friendly")
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  points RoutePoint[]
  stops  RouteStop[]
  type   String?        // "historia", "cultura", "gastronomia", "ecoturismo"

  @@map("routes")
}

enum Difficulty {
  easy
  medium
  hard
}

model RoutePoint {
  id        String  @id @default(uuid())
  routeId   String  @map("route_id")
  order     Int
  markerId  String? @map("marker_id")
  name      String
  latitude  Float
  longitude Float
  description String?

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("route_points")
}

// ==================== MAP MARKERS ====================

model Marker {
  id                String   @id @default(uuid())
  name              String
  category          MarkerCategory
  description       String?
  lat               Float
  lng               Float
  imageUrl          String?  @map("image_url")
  isPremiumBusiness Boolean  @default(false) @map("is_premium_business")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("markers")
}

enum MarkerCategory {
  site
  business
  viewpoint
  nature
  culture
  food
}

// ==================== TIPS & DONATIONS ====================

model Tip {
  id                  String      @id @default(uuid())
  fromUserId          String?     @map("from_user_id")
  toType              TipType     @map("to_type")
  toBusinessId        String?     @map("to_business_id")
  amount              Decimal     @db.Decimal(10, 2)
  currency            String      @default("MXN")
  message             String?
  paymentProvider     String      @map("payment_provider")
  providerPaymentId   String      @map("provider_payment_id")
  status              TipStatus   @default(pending)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  fromUser   User?     @relation("TipsSent", fields: [fromUserId], references: [id], onDelete: SetNull)
  toBusiness Business? @relation("TipsToBusiness", fields: [toBusinessId], references: [id], onDelete: SetNull)

  @@map("tips")
}

enum TipType {
  app
  business
}

enum TipStatus {
  pending
  succeeded
  failed
  refunded
}

// ==================== ANALYTICS ====================

model AnalyticsEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  eventType   String   @map("event_type")
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([createdAt])
  @@map("analytics_events")
}

// ==================== AI & CHAT ====================

model AiSession {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  mode      AiMode   @default(tourist)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages AiMessage[]

  @@map("ai_sessions")
}

enum AiMode {
  tourist
  business
}

model AiMessage {
  id        String    @id @default(uuid())
  sessionId String    @map("session_id")
  sender    Sender
  content   String
  actions   Json?     // Store suggested actions as JSON
  createdAt DateTime  @default(now()) @map("created_at")

  session AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

enum Sender {
  user
  realito
}

// ==================== LIVE EVENTS (Real-time recommendations) ====================

model LiveEvent {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String        // "cultural", "gastronomico", "musical", "religioso", etc.
  startsAt    DateTime      @map("starts_at")
  endsAt      DateTime      @map("ends_at")
  latitude    Float
  longitude   Float
  address     String?
  imageUrl    String?       @map("image_url")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  
  // Optional: link with a business
  businessId  String?       @map("business_id")
  business    Business?     @relation(fields: [businessId], references: [id])

  @@index([startsAt])
  @@index([endsAt])
  @@index([category])
  @@map("live_events")
}

// ==================== CONTENT SECTIONS (Narrative) ====================

model ContentSection {
  id          String   @id @default(uuid())
  slug        String   @unique  // "historia", "cultura", "gastronomia", "ecoturismo"
  title       String
  description String?
  type        String            // "historia", "cultura", "gastronomia", "ecoturismo"
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  // Relations
  blocks      ContentBlock[]

  @@map("content_sections")
}

model ContentBlock {
  id          String   @id @default(uuid())
  sectionId   String   @map("section_id")
  order       Int
  title       String
  subtitle    String?
  body        String
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  section         ContentSection          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  recommendations ContentRecommendation[]

  @@map("content_blocks")
}

model ContentRecommendation {
  id          String   @id @default(uuid())
  blockId     String   @map("block_id")
  businessId  String   @map("business_id")
  order       Int
  reason      String?  // Why this business is recommended for this block
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  block       ContentBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("content_recommendations")
}

// ==================== ROUTE STOPS ====================

model RouteStop {
  id          String   @id @default(uuid())
  routeId     String   @map("route_id")
  order       Int
  name        String
  latitude    Float
  longitude   Float
  description String?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  route       Route          @relation(fields: [routeId], references: [id], onDelete: Cascade)
  businesses  RouteStopBusiness[]

  @@map("route_stops")
}

model RouteStopBusiness {
  id          String   @id @default(uuid())
  routeStopId String   @map("route_stop_id")
  businessId  String   @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  routeStop   RouteStop @relation(fields: [routeStopId], references: [id], onDelete: Cascade)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([routeStopId, businessId])
  @@map("route_stop_businesses")
// ==================== KNOWLEDGE BASE ====================

model KnowledgeDocument {
  id          String            @id @default(uuid())
  type        KnowledgeType     @map("knowledge_type")
  source      String            @default("CMS")
  title       String
  content     String
  metadata    Json?
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("knowledge_documents")
}

enum KnowledgeType {
  DICHO
  HISTORIA
  CULTURA
  RUTA
  EVENTO
  LUGAR
  NEGOCIO
}

// ==================== GEN-7+ ISABELLA DECISIONS ====================

model IsabellaDecision {
  id              String            @id @default(uuid())
  traceId         String            @unique @map("trace_id")
  territory       String            @default("RDM")
  level           DecisionLevel     @map("decision_level")
  retentionIntent RetentionIntent   @map("retention_intent")
  pattern         TouristPattern    @map("tourist_pattern")
  scoreTotal      Float             @map("score_total")
  scoreFactors    Json              @map("score_factors")
  scoreConfidence Float             @map("score_confidence")
  distanceToExit  Float             @map("distance_to_exit")
  speedMps        Float             @map("speed_mps")
  latitude        Float
  longitude       Float
  payloadTitle    String            @map("payload_title")
  payloadMessage  String            @map("payload_message")
  rutaArActivada  Boolean           @default(false) @map("ruta_ar_activada")
  experienciaSugerida String?       @map("experiencia_sugerida")
  federacionDestino   String?       @map("federacion_destino")
  turistaId       String?           @map("turista_id")
  sessionId       String?           @map("session_id")
  createdAt       DateTime          @default(now()) @map("created_at")

  // Relations
  feedback        DecisionFeedback?
  tourist         TouristTracking?  @relation(fields: [turistaId], references: [id], onDelete: SetNull)

  @@index([territory])
  @@index([level])
  @@index([retentionIntent])
  @@index([createdAt])
  @@map("isabella_decisions")
}

enum DecisionLevel {
  CRITICO
  ALERTA
  INFO
  SUGERENCIA
}

enum RetentionIntent {
  SAFE_EXIT
  UPSELL
  DISCOVERY
  RETENTION
  ENGAGEMENT
}

enum TouristPattern {
  EXPLORING
  EXITING
  IDLE
  RETURNING
  LINGERING
}

// ==================== DECISION FEEDBACK ====================

model DecisionFeedback {
  id              String          @id @default(uuid())
  decisionId      String          @unique @map("decision_id")
  rating          Int             // 1-5
  feedback        String?
  consentimiento  Boolean         @default(false)
  actionTaken     Boolean         @default(false) @map("action_taken")
  createdAt       DateTime        @default(now()) @map("created_at")

  decision        IsabellaDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@map("decision_feedback")
}

// ==================== TOURIST TRACKING (GEN-7+) ====================

model TouristTracking {
  id                String            @id @default(uuid())
  sessionId         String            @unique @map("session_id")
  territory         String            @default("RDM")
  latitude          Float
  longitude         Float
  prevLatitude      Float?            @map("prev_latitude")
  prevLongitude     Float?            @map("prev_longitude")
  stayTimeHours     Float             @default(0) @map("stay_time_hours")
  lastInteractionAt DateTime          @map("last_interaction_at")
  firstSeenAt       DateTime          @map("first_seen_at")
  lastMovementAt    DateTime?         @map("last_movement_at")
  deviceType        String?           @map("device_type")
  referrer          String?
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  decisions         IsabellaDecision[]

  @@index([territory])
  @@index([isActive])
  @@index([lastInteractionAt])
  @@map("tourist_tracking")
}

// ==================== HEPTAFEDERATION TELEMETRY ====================

model FederationTelemetry {
  id                String            @id @default(uuid())
  moduleId          String            @map("module_id")
  moduleName        String            @map("module_name")
  specialty         String
  status            FederationStatus  @default(ACTIVE)
  health            Float             @default(1.0)
  operationalScore  Float             @default(1.0) @map("operational_score")
  recordedAt        DateTime          @default(now()) @map("recorded_at")

  @@index([moduleId])
  @@index([recordedAt])
  @@map("federation_telemetry")
}

enum FederationStatus {
  ACTIVE
  IDLE
  DEGRADED
  OFFLINE
}

// ==================== ZONE SATURATION ====================

model ZoneSaturation {
  id              String    @id @default(uuid())
  zoneId          String    @map("zone_id")
  zoneName        String    @map("zone_name")
  saturation      Float     @default(0) // 0.0 - 1.0
  activeTourists  Int       @default(0) @map("active_tourists")
  alertLevel      String?   @map("alert_level")
  recordedAt      DateTime  @default(now()) @map("recorded_at")

  @@index([zoneId])
  @@index([recordedAt])
  @@map("zone_saturation")
}

// ==================== AUTOPOIESIS LOG ====================

model AutopoiesisLog {
  id            String              @id @default(uuid())
  eventType     AutopoiesisEventType @map("event_type")
  entityType    String              @map("entity_type")
  entityId      String?             @map("entity_id")
  description   String
  metadata      Json?
  severity      String              @default("INFO")
  traceId       String?             @map("trace_id")
  createdAt     DateTime            @default(now()) @map("created_at")

  @@index([eventType])
  @@index([entityType])
  @@index([createdAt])
  @@map("autopoiesis_log")
}

enum AutopoiesisEventType {
  CREATION
  MODIFICATION
  DELETION
  STATE_CHANGE
  RELATIONSHIP
  EVOLUTION
  ANOMALY
  CORRECTION
  DECISION_EMITTED
  FEDERATION_DEGRADED
  SATURATION_ALERT
}

// ==================== SOVEREIGN IDENTITY (SSI) ====================

model SovereignIdentity {
  id              String            @id @default(uuid())
  did             String            @unique // Decentralized Identifier
  publicKey       String            @map("public_key")
  recoveryKeys    String[]          @map("recovery_keys")
  sovereigntyLevel SovereigntyLevel @default(INDIVIDUAL) @map("sovereignty_level")
  status          IdentityStatus    @default(PENDING)
  nodeId          String?           @map("node_id")
  userId          String?           @unique @map("user_id")
  metadata        Json?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([did])
  @@index([status])
  @@map("sovereign_identities")
}

enum SovereigntyLevel {
  INDIVIDUAL
  COMMUNITY
  INSTITUTIONAL
  FEDERAL
}

enum IdentityStatus {
  PENDING
  ACTIVE
  REVOKED
  RECOVERING
  FROZEN
}

// ==================== CIVIL NODES ====================

model CivilNode {
  id                  String              @id @default(uuid())
  name                String
  region              String
  trustScore          Float               @default(0) @map("trust_score")
  certificationLevel  CertificationLevel  @default(LEVEL_0) @map("certification_level")
  status              NodeStatus          @default(PROVISIONING)
  metadata            Json?
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([status])
  @@index([certificationLevel])
  @@index([region])
  @@map("civil_nodes")
}

enum CertificationLevel {
  LEVEL_0
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

enum NodeStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  DECOMMISSIONED
  QUARANTINED
}
