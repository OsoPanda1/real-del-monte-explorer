# ==================== SERVER CONFIG ====================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ==================== DATABASE ====================
DATABASE_URL=postgresql://user:password@localhost:5432/rdm_digital

# ==================== AUTHENTICATION ====================
# Generate a secure random string for JWT_SECRET
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_EXPIRES_IN=7d

# ==================== STRIPE PAYMENTS ====================
# Get these from Stripe Dashboard (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ==================== OPENAI (REALITO AI) ====================
# Get API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# ==================== SUPABASE (STORAGE) ====================
SUPABASE_URL=https://dwjaomisrpdzssqzhrtx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=rdm-digital

# ==================== AWS S3 (Alternative Storage) ====================
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=rdm-digital

# ==================== NEWSLETTER PROVIDER ====================
# Mailchimp/Brevo/SendGrid API key
# NEWSLETTER_PROVIDER_API_KEY=xxxxx
# NEWSLETTER_WEBHOOK_SECRET=xxxxx

# ==================== EMAIL (SMTP) ====================
# For sending password reset emails, etc.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=xxxxx
# SMTP_PASS=xxxxx
# SMTP_FROM=noreply@real-del-monte.com

# ==================== FILE UPLOADS ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ==================== LOGGING ====================
LOG_LEVEL=info
